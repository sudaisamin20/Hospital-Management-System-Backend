<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: white;
            margin: 0;
            padding: 0;
        }

        @media print {
            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }
        }

        .prescription-symbol {
            font-size: 48px;
            font-weight: bold;
            color: #2563eb;
            font-family: 'Times New Roman', serif;
        }

        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 100px;
            color: rgba(0, 0, 0, 0.02);
            font-weight: bold;
            z-index: -1;
            pointer-events: none;
        }
    </style>
</head>

<body class="bg-white">

    <!-- Watermark -->
    <div class="watermark">PRESCRIPTION</div>

    <div class="max-w-4xl mx-auto bg-white p-5">

        <!-- Header with Hospital Info -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white p-3 rounded-t-lg -mx-5 -mt-5 mb-4">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-2xl font-bold mb-1">CityCare Hospital</h1>
                    <p class="text-blue-100 text-sm">123 Medical Center Drive, Healthcare City</p>
                    <p class="text-blue-100 text-sm">Phone: +1 (555) 123-4567 | Email: info@citycare.com</p>
                    <p class="text-blue-100 text-sm">Emergency: +1 (555) 911-0000</p>
                </div>
            </div>
        </div>

        <!-- Prescription Header -->
        <div class="text-center mb-4 pb-2 border-b-2 border-blue-600">
            <h2 class="text-xl font-bold text-gray-800">MEDICAL PRESCRIPTION</h2>
            <h4 class="text-gray-600 font-medium text-sm">Prescription ID: <%= prescriptionId %>
            </h4>
        </div>

        <!-- Doctor Information -->
        <div class="mb-3">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Doctor Name</p>
                    <p class="font-bold text-gray-800">
                        <%= doctorName %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Date</p>
                    <p class="font-semibold text-gray-800">
                        <%= date %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Patient Name</p>
                    <p class="font-bold text-gray-800">
                        <%= patientName %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Patient ID</p>
                    <p class="font-semibold text-gray-800 font-mono">
                        <%= patientId %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Age / Gender</p>
                    <p class="font-semibold text-gray-800">
                        <%= patientAge %> Years / <%= patientGender %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Contact</p>
                    <p class="font-semibold text-gray-800">
                        <%= patientContact || 'N/A' %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Symptoms -->
        <%= symptoms ? <div class="mb-3">
            <div>
                <h3 class="text-sm font-bold text-gray-700 mb-1">Diagnosis</h3>
                <p class="text-sm text-gray-800">
                    <%= symptoms %>
                </p>
            </div>
    </div> : ""
    %>

    <!-- Chief Complaint & Diagnosis -->
    <div class="mb-3">
        <div>
            <h3 class="text-sm font-bold text-gray-700 mb-1">Diagnosis</h3>
            <p class="text-sm text-gray-800">
                <%= diagnosis %>
            </p>
        </div>
    </div>

    <!-- Vital Signs (Optional) -->
    <% if (vitalSigns && Object.keys(vitalSigns).length> 0) { %>
        <div class="mb-1">
            <h3 class="text-sm font-bold text-gray-900 mb-1">Vital Signs</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs">
                <% if (vitalSigns.bloodPressure) { %>
                    <div>
                        <p class="text-gray-700 font-medium">Blood Pressure</p>
                        <p class="text-gray-800 font-semibold">
                            <%= vitalSigns.bloodPressure %> mmHg
                        </p>
                    </div>
                    <% } %>
                        <% if (vitalSigns.heartRate) { %>
                            <div>
                                <p class="text-gray-700 font-medium">Heart Rate</p>
                                <p class="text-gray-800 font-semibold">
                                    <%= vitalSigns.heartRate %> bpm
                                </p>
                            </div>
                            <% } %>
                                <% if (vitalSigns.temperature) { %>
                                    <div>
                                        <p class="text-gray-700 font-medium">Temperature</p>
                                        <p class="text-gray-800 font-semibold">
                                            <%= vitalSigns.temperature %> °F
                                        </p>
                                    </div>
                                    <% } %>
                                        <% if (vitalSigns.weight) { %>
                                            <div>
                                                <p class="text-gray-700 font-medium">Weight</p>
                                                <p class="text-gray-800 font-semibold">
                                                    <%= vitalSigns.weight %> kg
                                                </p>
                                            </div>
                                            <% } %>
            </div>
        </div>
        <% } %>

            <!-- Medicines Table -->
            <div class="mb-3">
                <h3 class="text-lg font-bold text-gray-800 mb-2 pb-1 border-b border-gray-300">
                    PRESCRIBED MEDICINES
                </h3>

                <table class="w-full">
                    <thead>
                        <tr class="text-gray-700">
                            <th class="py-2 text-left font-semibold border-b border-gray-300">#</th>
                            <th class="p-2 text-left font-semibold border-b border-gray-300">Medicine Name
                            </th>
                            <th class="p-2 text-center font-semibold border-b border-gray-300">Dosage</th>
                            <th class="p-2 text-center font-semibold border-b border-gray-300">Frequency</th>
                            <th class="p-2 text-center font-semibold border-b border-gray-300">Duration</th>
                            <th class="p-2 text-center font-semibold border-b border-gray-300">Timing</th>
                            <th class="p-2 text-center font-semibold border-b border-gray-300">Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% medicines?.forEach((medicine, index)=> { %>
                            <tr class="">
                                <td class="py-2 text-center font-bold text-gray-800">
                                    <%= index + 1 %>
                                </td>
                                <td class="p-2 text-left font-semibold text-gray-800">
                                    <p class="font-bold text-gray-900">
                                        <%= medicine.medicineName %>
                                    </p>
                                    <% if (medicine.instructions) { %>
                                        <p class="text-xs text-gray-600 italic mt-1">
                                            Note: <%= medicine.instructions %>
                                        </p>
                                        <% } %>
                                </td>
                                <td class="p-2 text-center font-semibold text-gray-800">
                                    <%= medicine.dosage %> mg
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <%= medicine.frequency %>x daily
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <%= medicine.duration %> days
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <%= medicine.timing %>
                                </td>
                                <td class="p-2 text-center font-semibold text-gray-700">
                                    <%= medicine.quantity || (medicine.frequency * medicine.duration) %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Follow Up -->
            <% if (followUp) { %>
                <div class="mb-3">
                    <h3 class="text-sm font-bold text-gray-700 mb-1">Follow-up</h3>
                    <p class="text-sm text-gray-800">
                        <% if (followUp.duration) { %>
                            Please schedule a follow-up appointment after <strong>
                                <%= followUp.duration %>
                            </strong>
                            <% } %>
                                <% if (followUp.notes) { %>
                                    <br>
                                    <%= followUp.notes %>
                                        <% } %>
                    </p>
                </div>
                <% } %>

                    <!-- Important Instructions -->
                    <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-3">
                        <p class="text-xs text-red-800 font-semibold mb-2">⚠️ IMPORTANT
                            INSTRUCTIONS</p>
                        <ul class="text-xs text-red-700 space-y-1 list-disc list-inside">
                            <li>Take medicines exactly as prescribed by the doctor</li>
                            <li>Complete the full course of medication even if you feel
                                better</li>
                            <li>Do not share your medicines with others</li>
                            <li>Store medicines in a cool, dry place away from children</li>
                            <li>Contact your doctor immediately if you experience any
                                adverse reactions</li>
                            <li>This prescription is valid for 30 days from the date of
                                issue</li>
                        </ul>
                    </div>

                    <!-- Footer -->
                    <div class="bg-gray-100 -mx-10 -mb-10 p-6 rounded-b-lg border-t-4 border-blue-600">
                        <div class="flex justify-between items-center text-xs text-gray-600">
                            <div>
                                <p class="font-semibold">Prescription ID: <%= prescriptionId || 'PRS-' + Date.now() %>
                                </p>
                                <p>Generated: <%= new Date().toLocaleString() %>
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold">CityCare Hospital</p>
                                <p>ISO 9001:2015 Certified | JCI Accredited</p>
                                <p class="text-xs text-gray-500 mt-1">This is a
                                    computer-generated prescription</p>
                            </div>
                        </div>
                    </div>

                    </div>

</body>

</html>