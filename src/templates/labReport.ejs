<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: white;
            margin: 0;
            padding: 0;
        }

        @media print {
            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }
        }

        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 120px;
            color: rgba(0, 0, 0, 0.03);
            font-weight: bold;
            z-index: -1;
            pointer-events: none;
        }
    </style>
</head>

<body class="bg-white">

    <!-- Watermark -->
    <div class="watermark">CONFIDENTIAL</div>

    <div class="max-w-4xl mx-auto bg-white p-5">

        <!-- Header with Logo and Hospital Info -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white p-3 -mx-5 -mt-5 mb-4">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-2xl font-bold mb-1">Hospital Management System</h1>
                    <p class="text-blue-100 text-sm">123 Medical Center Drive, Healthcare City</p>
                    <p class="text-blue-100 text-sm">Phone: +1 (555) 123-4567 | Email: lab@citycare.com</p>
                    <p class="text-blue-100 text-sm">Lab License: LAB-2024-12345</p>
                </div>
            </div>
        </div>

        <!-- Report Title -->
        <div class="text-center mb-4 pb-2 border-b-2 border-blue-600">
            <h2 class="text-xl font-bold text-gray-800 mb-1">LABORATORY TEST REPORT</h2>
        </div>

        <!-- Patient and Test Information -->
        <div class="grid grid-cols-2 gap-3 mb-4">
            <!-- Left Column -->
            <div class="space-y-2">
                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Patient Name</p>
                    <p class="font-bold text-gray-800 text-lg">
                        <%= patientName %>
                    </p>
                </div>

                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Patient ID</p>
                    <p class="font-semibold text-gray-800">
                        <%= patientId || 'N/A' %>
                    </p>
                </div>

                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Age / Gender</p>
                    <p class="font-semibold text-gray-800">
                        <%= age || 'N/A' %> / <%= gender || 'N/A' %>
                    </p>
                </div>
            </div>

            <!-- Right Column -->
            <div class="space-y-2">
                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Referring Doctor</p>
                    <p class="font-bold text-gray-800 text-lg">
                        <%= doctorName %>
                    </p>
                </div>

                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Test Name</p>
                    <p class="font-semibold text-gray-800">
                        <%= testName %>
                    </p>
                </div>

                <div class="">
                    <p class="text-xs text-gray-700 font-semibold uppercase mb-1">Report Date</p>
                    <p class="font-semibold text-gray-800">
                        <%= date %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Test Results Table -->
        <div class="mb-4">
            <h3 class="text-lg font-bold text-gray-800 mb-2 pb-1 border-b border-gray-300">
                TEST RESULTS
            </h3>

            <table class="w-full">
                <thead>
                    <tr class="text-gray-700">
                        <th class="py-2 text-left font-semibold border-b border-gray-600">Parameter</th>
                        <th class="p-2 text-center font-semibold border-b border-gray-600">Result</th>
                        <th class="p-2 text-center font-semibold border-b border-gray-600">Range</th>
                        <th class="p-2 text-center font-semibold border-b border-gray-600">Unit</th>
                        <th class="p-2 text-center font-semibold border-b border-gray-600">Status</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (Array.isArray(testResults) && testResults.length> 0) { %>
                        <% testResults.forEach((result, index)=> { %>
                            <tr class="">
                                <td class="py-2 font-medium text-gray-800">
                                    <%= result.parameter || result.name || 'N/A' %>
                                </td>
                                <td class="p-2 text-center font-bold text-gray-700">
                                    <%= result.result || result.value || 'N/A' %>
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <%= result.referenceRange || result.range || 'N/A' %>
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <%= result.unit || '-' %>
                                </td>
                                <td class="p-2 text-center text-gray-700">
                                    <% const status=result.status || 'Normal' ; %>
                                        <% if (status==='Normal' || status==='normal' ) { %>
                                            <span class="text-xs font-semibold">
                                                NORMAL
                                            </span>
                                            <% } else if (status==='High' || status==='high' ) { %>
                                                <span class="text-xs font-semibold">
                                                    HIGH
                                                </span>
                                                <% } else if (status==='Low' || status==='low' ) { %>
                                                    <span class="text-xs font-semibold">
                                                        LOW
                                                    </span>
                                                    <% } else { %>
                                                        <span class="text-xs font-semibold">
                                                            <%= status %>
                                                        </span>
                                                        <% } %>
                                </td>
                            </tr>
                            <% }); %>
                                <% } %>
                </tbody>
            </table>
        </div>

        <!-- Remarks Section -->
        <div class="mb-4">
            <h3 class="text-lg font-bold text-gray-800 mb-2 flex items-center">
                Remarks
            </h3>
            <p class="text-gray-800 leading-relaxed">
                <%= remarks || 'No additional remarks.' %>
            </p>
        </div>

        <!-- Lab Technician Signature -->
        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <div class="border-t border-gray-400 pt-2">
                    <p class="font-semibold text-gray-800">
                        <%= technicianName || 'Lab Technician' %>
                    </p>
                    <p class="text-sm text-gray-600">Lab Technician</p>
                    <p class="text-xs text-gray-700">License: <%= technicianLicense || 'LT-12345' %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Important Notice -->
        <div class="bg-red-50 border border-red-200 rounded-lg p-2 mb-3">
            <p class="text-xs text-red-800 font-semibold mb-2">⚠️ IMPORTANT NOTICE</p>
            <ul class="text-xs text-red-700 space-y-1 list-disc list-inside">
                <li>This report is intended for the exclusive use of the referring physician and patient</li>
                <li>Test results should be correlated with clinical findings</li>
                <li>This is a computer-generated report and does not require a signature</li>
                <li>In case of any discrepancy, please contact the laboratory immediately</li>
            </ul>
        </div>

        <!-- Footer -->
        <div class="bg-gray-100 -mx-5 -mb-5 p-3 border-t-2 border-blue-600">
            <div class="flex justify-between items-center text-xs text-gray-600">
                <div>
                    <p class="font-semibold">Report ID: <%= reportId || 'RPT-' + Date.now() %>
                    </p>
                    <p>Generated: <%= new Date().toLocaleString() %>
                    </p>
                </div>
                <div class="text-right">
                    <p class="font-semibold">CityCare Hospital Laboratory</p>
                    <p>ISO 9001:2015 Certified | NABL Accredited</p>
                </div>
            </div>
        </div>

    </div>

</body>

</html>